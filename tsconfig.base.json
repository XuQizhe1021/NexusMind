{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@nexusmind/core": [
        "packages/core/src/index.ts"
      ],
      "@nexusmind/core/*": [
        "packages/core/src/*"
      ],
      "@nexusmind/ai": [
        "packages/ai/src/index.ts"
      ],
      "@nexusmind/ai/*": [
        "packages/ai/src/*"
      ],
      "@nexusmind/graph": [
        "packages/graph/src/index.ts"
      ],
      "@nexusmind/graph/*": [
        "packages/graph/src/*"
      ],
      "@nexusmind/billing": [
        "packages/billing/src/index.ts"
      ],
      "@nexusmind/billing/*": [
        "packages/billing/src/*"
      ],
      "@nexusmind/ui": [
        "packages/ui/src/index.ts"
      ],
      "@nexusmind/ui/*": [
        "packages/ui/src/*"
      ]
    }
  }
}
